NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Required
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret

# Frontend URL used for QR scan links and CORS allowlist.
# You can set multiple origins as comma-separated values.
APP_ORIGIN=https://your-frontend.up.railway.app
CORS_ORIGIN=https://your-frontend.up.railway.app

# Optional debug endpoint toggle. Keep false in production.
ENABLE_DEBUG_ENDPOINTS=false

# Optional one-time super-admin seeding on deployment.
# Turn on only when you intentionally need bootstrap account creation.
SEED_SUPERADMIN=false
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=replace-with-strong-password
